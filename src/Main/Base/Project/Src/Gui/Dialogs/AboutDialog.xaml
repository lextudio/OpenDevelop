<Window x:Class="ICSharpCode.SharpDevelop.Gui.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About OpenDevelop"
        Width="560" Height="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        ShowInTaskbar="False">
  <Window.Resources>
    <Style TargetType="TabItem">
      <Setter Property="Padding" Value="8,2" />
    </Style>
  </Window.Resources>

  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Grid Grid.Row="0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="220" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0" BorderBrush="#C0C0C0" BorderThickness="1" Margin="0,0,8,0" ClipToBounds="True">
        <Canvas x:Name="quoteCanvas" Background="#F5F5F5" Width="220" Height="320">
          <TextBlock x:Name="aboutImage" Width="220" Height="320"
                     Text="OpenDevelop" FontSize="28" FontWeight="Bold"
                     TextAlignment="Center" VerticalAlignment="Center"
                     Foreground="#E0E0E0" />
        </Canvas>
      </Border>

      <TabControl Grid.Column="1">
        <TabItem Header="About">
          <Grid Margin="8">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Margin="0,0,0,4" TextWrapping="Wrap">
              OpenDevelop is a modernized fork of SharpDevelop for .NET on WPF.
            </TextBlock>
            <TextBox Grid.Row="1"
                     x:Name="VersionInfoBox"
                     IsReadOnly="True"
                     FontFamily="Global Monospace, Courier New, Consolas"
                     FontSize="11"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     TextWrapping="NoWrap" />
          </Grid>
        </TabItem>
        <TabItem Header="Version Info">
          <Grid Margin="8">
            <Grid.RowDefinitions>
              <RowDefinition Height="*" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <ListView x:Name="AssemblyList"
                      Grid.Row="0"
                      Margin="0,0,0,4">
              <ListView.View>
                <GridView>
                  <GridViewColumn Header="Name" Width="160" DisplayMemberBinding="{Binding Name}" />
                  <GridViewColumn Header="Version" Width="80" DisplayMemberBinding="{Binding Version}" />
                  <GridViewColumn Header="Path" Width="160" DisplayMemberBinding="{Binding Location}" />
                </GridView>
              </ListView.View>
            </ListView>
            <Button Grid.Row="1" Content="Copy" Width="75" Height="24" HorizontalAlignment="Left"
                    Click="OnCopyClick" />
          </Grid>
        </TabItem>
      </TabControl>
    </Grid>

    <StackPanel Grid.Row="1" Margin="0,8,0,4">
      <TextBlock x:Name="VersionText" FontSize="12" />
      <TextBlock x:Name="CopyrightText" FontSize="12" />
    </StackPanel>

    <Button Grid.Row="2" Content="OK" Width="75" Height="24"
            HorizontalAlignment="Right" Click="OnOkClick" IsDefault="True" />
  </Grid>
</Window>
