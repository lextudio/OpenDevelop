<UserControl x:Class="ICSharpCode.SharpDevelop.Services.ProjectBrowserView"
             x:ClassModifier="internal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:services="clr-namespace:ICSharpCode.SharpDevelop.Services"
             xmlns:automation="clr-namespace:System.Windows.Automation;assembly=PresentationCore">
    <UserControl.Resources>
        <HierarchicalDataTemplate DataType="{x:Type services:ProjectBrowserNodeModel}"
                                  ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal">
                <Grid Width="16"
                      Height="16"
                      Margin="0,0,4,0">
                    <Image Width="16"
                           Height="16"
                           Source="{Binding Icon}" />
                    <Image Width="8"
                           Height="8"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Bottom"
                           Source="{Binding OverlayIcon}"
                           automation:AutomationProperties.AutomationId="{Binding OverlayStatusKey}" />
                </Grid>
                <TextBlock Text="{Binding Name}" />
            </StackPanel>
        </HierarchicalDataTemplate>
    </UserControl.Resources>
    <DockPanel>
        <ToolBar DockPanel.Dock="Top"
                 ToolBarTray.IsLocked="True"
                 KeyboardNavigation.TabNavigation="None">
            <Button Command="{Binding ShowPropertiesCommand}"
                    ToolTip="Properties"
                    Padding="3">
                <Image Width="16"
                       Height="16"
                       Source="{Binding PropertiesIcon}" />
            </Button>
            <Separator />
            <ToggleButton IsChecked="{Binding ShowAllFiles, Mode=TwoWay}"
                          ToolTip="Show All Files"
                          Padding="3">
                <Image Width="16"
                       Height="16"
                       Source="{Binding ShowAllFilesIcon}" />
            </ToggleButton>
            <Button Command="{Binding RefreshCommand}"
                    ToolTip="Refresh"
                    Padding="3">
                <Image Width="16"
                       Height="16"
                       Source="{Binding RefreshIcon}" />
            </Button>
            <Button Command="{Binding CollapseAllCommand}"
                    ToolTip="Collapse All"
                    Padding="3">
                <Image Width="16"
                       Height="16"
                       Source="{Binding CollapseAllIcon}" />
            </Button>
        </ToolBar>
        <TreeView x:Name="treeView"
                  BorderThickness="0"
                  ItemsSource="{Binding RootNodes}"
                  MouseDoubleClick="TreeViewOnMouseDoubleClick"
                  PreviewMouseRightButtonDown="TreeViewOnPreviewMouseRightButtonDown"
                  SelectedItemChanged="TreeViewOnSelectedItemChanged">
            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=OneWay}" />
                </Style>
            </TreeView.ItemContainerStyle>
        </TreeView>
    </DockPanel>
</UserControl>
