<Project Sdk="LibreWPF.Sdk/11.0.0-dev">
  <PropertyGroup>
    <TargetFramework>net10.0-windows</TargetFramework>
    <RootNamespace>HexEditor</RootNamespace>
    <AssemblyName>HexEditor</AssemblyName>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <UseWPF>true</UseWPF>
    <OutputType>Library</OutputType>
    <SignAssembly>true</SignAssembly>
    <AssemblyOriginatorKeyFile>..\..\..\..\Main\ICSharpCode.SharpDevelop.snk</AssemblyOriginatorKeyFile>
    <OutputPath>..\..\..\..\..\AddIns\DisplayBindings\HexEditor\</OutputPath>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <!-- The dual hex/text pane rendering, caret, selection, undo/redo, hex-nibble input mode,
         and clipboard behavior of the original WinForms/GDI+ Editor control are all preserved -
         only the drawing/input APIs were translated to WPF (DrawingContext/FormattedText instead
         of Graphics/TextRenderer, System.Windows.Input instead of System.Windows.Forms).
         HexEditOptionsPanel/HexEditContainer/FontChooserDialog are built in code (no .xaml) - a
         .xaml Page item here hit a WPF markup-compile temp-project duplicate-Compile-item error
         against this project's custom OutputPath layout. -->
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="..\..\..\..\Main\GlobalAssemblyInfo.cs" Link="Configuration\GlobalAssemblyInfo.cs" />
    <None Include="HexEditor.addin" CopyToOutputDirectory="Always" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\..\..\Libraries\AvalonEdit\ICSharpCode.AvalonEdit\ICSharpCode.AvalonEdit.csproj" Private="false" />
    <ProjectReference Include="..\..\..\..\Main\Base\Project\ICSharpCode.SharpDevelop.csproj" Private="false" />
    <ProjectReference Include="..\..\..\..\Main\Core\Project\ICSharpCode.Core.csproj" Private="false" />
    <ProjectReference Include="..\..\..\..\Main\ICSharpCode.Core.Presentation\ICSharpCode.Core.Presentation.csproj" Private="false" />
    <ProjectReference Include="..\..\..\..\Main\ICSharpCode.SharpDevelop.Widgets\Project\ICSharpCode.SharpDevelop.Widgets.csproj" Private="false" />
  </ItemGroup>
</Project>
