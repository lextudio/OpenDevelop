<Project Sdk="LibreWPF.Sdk/11.0.0-dev">
  <PropertyGroup>
    <TargetFramework>net10.0-windows</TargetFramework>
    <RootNamespace>ResourceEditor</RootNamespace>
    <AssemblyName>ResourceEditor</AssemblyName>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <UseWPF>true</UseWPF>
    <OutputType>Library</OutputType>
    <SignAssembly>true</SignAssembly>
    <AssemblyOriginatorKeyFile>..\..\..\..\Main\ICSharpCode.SharpDevelop.snk</AssemblyOriginatorKeyFile>
    <OutputPath>..\..\..\..\..\AddIns\DisplayBindings\ResourceEditor\</OutputPath>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <!-- Migrated from legacy binary-typed (System.Drawing.Bitmap/Icon, System.Windows.Forms.Cursor)
         resource previews to a text/value grid model (name/type/value/comment), matching the
         precedent UnoDevelop's own ResourceViewerViewContent/IconCursorViewerViewContent already
         established for this addin's Uno port - OpenDevelop is WPF-only (no WinForms/
         LibreWinForms), so there is no cross-platform way to keep rendering those CLR types. -->
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="..\..\..\..\Main\GlobalAssemblyInfo.cs" Link="Configuration\GlobalAssemblyInfo.cs" />
    <!-- Depends on ICSharpCode.NRefactory.TypeSystem (removed elsewhere in this codebase already)
         and System.Resources.Tools.StronglyTypedResourceBuilder; not ported (see ResourceEditor.addin). -->
    <Compile Remove="Src\ResourceCodeGeneratorTool.cs" />
    <None Include="ResourceEditor.addin" CopyToOutputDirectory="Always" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\..\..\Libraries\NRefactory\ICSharpCode.NRefactory\ICSharpCode.NRefactory.csproj" Private="false" />
    <ProjectReference Include="..\..\..\..\Main\Base\Project\ICSharpCode.SharpDevelop.csproj" Private="false" />
    <ProjectReference Include="..\..\..\..\Main\Core\Project\ICSharpCode.Core.csproj" Private="false" />
    <ProjectReference Include="..\..\..\..\Main\ICSharpCode.Core.Presentation\ICSharpCode.Core.Presentation.csproj" Private="false" />
    <ProjectReference Include="..\..\..\..\Main\ICSharpCode.SharpDevelop.Widgets\Project\ICSharpCode.SharpDevelop.Widgets.csproj" Private="false" />
    <ProjectReference Include="..\..\..\..\Libraries\ResourceFiles\ResourceFiles.csproj" />
  </ItemGroup>
</Project>
