<UserControl x:Class="ICSharpCode.IconEditor.EditorPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ICSharpCode.IconEditor">
    <DockPanel>
        <Border DockPanel.Dock="Top" BorderBrush="Gray" BorderThickness="0,0,0,1" Padding="4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="View on color:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox x:Name="colorComboBox" Width="48" Height="22" Margin="0,0,8,0"
                          SelectedIndex="0"
                          SelectionChanged="ColorComboBoxSelectionChanged">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <Rectangle Width="32" Height="12" Fill="{Binding}" Margin="2"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button x:Name="addFormatButton" MinWidth="120" Height="22" Click="AddFormatButtonClick">Add Custom Format...</Button>
            </StackPanel>
        </Border>
        <TextBlock x:Name="infoTextBlock" DockPanel.Dock="Bottom"
                   Text="Right-click on the individual images to see more options."
                   Margin="4,2,4,2"/>
        <ScrollViewer x:Name="scrollViewer" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <Grid x:Name="table" Margin="4"/>
        </ScrollViewer>
    </DockPanel>
</UserControl>
