<Project Sdk="LibreWPF.Sdk/11.0.0-dev">
  <PropertyGroup>
    <TargetFramework>net10.0-windows</TargetFramework>
    <RootNamespace>ICSharpCode.WpfDesign.AddIn</RootNamespace>
    <AssemblyName>ICSharpCode.WpfDesign.AddIn</AssemblyName>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <OutputType>Library</OutputType>
    <OutputPath>..\..\..\..\..\AddIns\DisplayBindings\WpfDesign\</OutputPath>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <NoWarn>$(NoWarn);CA1416;WFO1000</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\..\..\externals\wpftoolkit\ExtendedWPFToolkitSolution\Src\Xceed.Wpf.Toolkit\Xceed.Wpf.Toolkit.csproj" />
    <ProjectReference Include="..\..\..\..\..\externals\vscode-wpf\external\WpfDesigner\WpfDesign.Designer\Project\WpfDesign.Designer.csproj" />
    <ProjectReference Include="..\..\..\..\..\externals\vscode-wpf\external\WpfDesigner\WpfDesign.XamlDom\Project\WpfDesign.XamlDom.csproj" />
    <ProjectReference Include="..\..\..\..\..\externals\vscode-wpf\external\WpfDesigner\WpfDesign\Project\WpfDesign.csproj" />
    <ProjectReference Include="..\..\..\..\Libraries\ICSharpCode.TypeSystem.Abstractions\ICSharpCode.TypeSystem.Abstractions.csproj" Private="False" />
    <ProjectReference Include="..\..\..\..\Main\Base\Project\ICSharpCode.SharpDevelop.csproj" Private="False" />
    <ProjectReference Include="..\..\..\..\Main\Core\Project\ICSharpCode.Core.csproj" Private="False" />
    <ProjectReference Include="..\..\..\..\Main\ICSharpCode.Core.Presentation\ICSharpCode.Core.Presentation.csproj" Private="False" />
    <ProjectReference Include="..\..\..\..\Main\ICSharpCode.Core.WinForms\ICSharpCode.Core.WinForms.csproj" Private="False" />
    <ProjectReference Include="..\..\..\..\Main\ICSharpCode.SharpDevelop.Widgets\Project\ICSharpCode.SharpDevelop.Widgets.csproj" Private="False" />
    <ProjectReference Include="..\..\..\..\..\..\wpf-labs\src\DevFlow\LeXtudio.DevFlow.Agent.Core\LeXtudio.DevFlow.Agent.Core.csproj" Private="False" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="..\..\..\..\Main\GlobalAssemblyInfo.cs" Link="Configuration\GlobalAssemblyInfo.cs" />
    <!-- Intentionally NOT CopyToOutputDirectory="Always": MSBuild propagates a project's own
         <None CopyToOutputDirectory> content items into every downstream consumer's own
         OutputPath (via GetCopyToOutputDirectoryItems walking the full transitive P2P closure),
         regardless of Private="false" on intermediate ProjectReference edges (Private only
         suppresses copying this project's own compiled assembly, not its content items). Since
         several unrelated addins (ILSpyAddIn, PackageManagement, CodeCoverage) transitively
         reference this project (e.g. via AvalonEdit.AddIn, which genuinely needs the WpfDesign.*
         assemblies at compile time), that propagation was duplicating "WpfDesign.addin" - and the
         AddInTree assemblies it pulls in - into their output folders too, each registering a
         conflicting duplicate "ICSharpCode.WpfDesigner" AddInTree identity at startup. The
         explicit AfterTargets="Build" copy below achieves the same "copy the manifest into this
         project's own output" result without exposing it as a propagating content item. -->
    <None Include="WpfDesign.addin" />
    <Resource Include="Images\Icons.32x32.Error.png" />
  </ItemGroup>

  <Target Name="CopyAddInManifest" AfterTargets="Build">
    <Copy SourceFiles="WpfDesign.addin" DestinationFolder="$(OutputPath)" SkipUnchangedFiles="true" />
  </Target>
</Project>
