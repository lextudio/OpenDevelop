<Project Sdk="LibreWPF.Sdk/11.0.0-dev">
  <PropertyGroup>
    <TargetFramework>net10.0-windows</TargetFramework>
    <RootNamespace>ICSharpCode.PackageManagement</RootNamespace>
    <AssemblyName>PackageManagement</AssemblyName>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <UseWPF>true</UseWPF>
    <EnableWindowsTargeting>true</EnableWindowsTargeting>
    <OutputType>Library</OutputType>
    <SignAssembly>true</SignAssembly>
    <AssemblyOriginatorKeyFile>..\..\..\..\Main\ICSharpCode.SharpDevelop.snk</AssemblyOriginatorKeyFile>
    <OutputPath>..\..\..\..\..\AddIns\Misc\PackageManagement\</OutputPath>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <NoWarn>$(NoWarn);CA1416;WFO1000</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <Reference Include="NuGet.Core">
      <HintPath>..\RequiredLibraries\NuGet.Core.dll</HintPath>
    </Reference>
    <ProjectReference Include="..\..\..\..\Libraries\ICSharpCode.TypeSystem.Abstractions\ICSharpCode.TypeSystem.Abstractions.csproj" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp.Workspaces" Version="5.3.0" />
    <!-- Real search engine (see NuGetPackageSearchService.cs): the legacy NuGet.Core repository's
         OData V2 client needs System.Data.Services.Client, which has no modern-.NET package - so
         remote (non-local-folder) sources cannot search through it at all on this runtime. Search
         goes through the real, current NuGet.Client protocol stack instead; results are adapted
         back into legacy IPackage so the rest of the (working) install/UI pipeline is untouched. -->
    <!-- Pinned to match the version already resolved transitively across the rest of the solution
         (src/Main/Base/Project/Src/Project/MSBuildInternals.cs, via the .NET SDK's own MSBuild/NuGet
         resolver) - a different version here loads a byte-different NuGet.Protocol/NuGet.Common
         assembly with the same strong name, which the runtime rejects with a FileLoadException
         since the main app's own MSBuild internals already loaded the other copy first. -->
    <PackageReference Include="NuGet.Protocol" Version="6.13.2" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\..\..\Main\Base\Project\ICSharpCode.SharpDevelop.csproj" Private="false" />
    <ProjectReference Include="..\..\..\..\Main\Core\Project\ICSharpCode.Core.csproj" Private="false" />
    <ProjectReference Include="..\..\..\..\Main\ICSharpCode.Core.Presentation\ICSharpCode.Core.Presentation.csproj" Private="false" />
    <ProjectReference Include="..\..\..\..\Libraries\AvalonEdit\ICSharpCode.AvalonEdit\ICSharpCode.AvalonEdit.csproj" Private="false" />
    <ProjectReference Include="..\..\..\BackendBindings\Scripting\Project\ICSharpCode.Scripting.csproj" Private="false" />
    <ProjectReference Include="..\..\..\DisplayBindings\AvalonEdit.AddIn\AvalonEdit.AddIn.csproj" Private="false" />
    <ProjectReference Include="..\SharpDevelop.EnvDTE\SharpDevelop.EnvDTE.vbproj" Private="false" />
    <ProjectReference Include="..\..\..\..\..\..\wpf-labs\src\DevFlow\LeXtudio.DevFlow.Agent.Core\LeXtudio.DevFlow.Agent.Core.csproj" Private="False" />
    <!-- PowerShell Package Console pad (Microsoft.PowerShell.SDK is cross-platform - PowerShell 7/
         Core is embedded in-process, no external PowerShell install/detection needed). -->
    <ProjectReference Include="..\PowerShell\Project\PackageManagement.PowerShell.csproj" Private="false" />
  </ItemGroup>
  <ItemGroup>
    <Compile Include="..\..\..\..\Main\GlobalAssemblyInfo.cs" Link="Configuration\GlobalAssemblyInfo.cs" />
    <None Include="PackageManagement.addin" CopyToOutputDirectory="Always" />
    <None Include="..\RequiredLibraries\LICENSE.txt" Link="NuGet-LICENSE.txt" CopyToOutputDirectory="Always" />
    <None Include="Scripts\Package.Format.ps1xml" CopyToOutputDirectory="Always" />
    <Resource Include="Resources\**\*" />
  </ItemGroup>
  <ItemGroup>
    <!-- MVP scope excludes the legacy WinForms/SharpTreeView ProjectBrowser. Package operations still
         update project files; the WPF Solution Explorer is refreshed through its own service path. -->
    <Compile Remove="Src\ProjectBrowserUpdater.cs" />
    <Compile Remove="Src\ThreadSafeProjectBrowserUpdater.cs" />
    <Compile Remove="Src\UpdateProjectBrowserFileNodesVisitor.cs" />
    <!-- ConsoleInitializer.cs/ComponentModel.cs are VS SDK/MEF-service shims (IConsoleInitializer,
         SComponentModel) for hosting this console inside Visual Studio's own service container -
         not applicable to our own WPF PackageManagementConsolePad, and IConsoleInitializer's type
         doesn't exist anywhere in this codebase (it came from the removed NuGet.Console.Types.dll). -->
    <Compile Remove="Src\Scripting\ConsoleInitializer.cs" />
    <Compile Remove="Src\VisualStudio\ComponentModel.cs" />
  </ItemGroup>
</Project>
