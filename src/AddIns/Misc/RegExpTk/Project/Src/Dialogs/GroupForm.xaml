<Window x:Class="Plugins.RegExpTk.GroupForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Match Groups" Height="300" Width="500"
        WindowStartupLocation="CenterOwner"
        Style="{x:Null}">
  <Grid Margin="6">
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <ListView Grid.Row="0" x:Name="groupsListView"
              Margin="0,0,0,6">
      <ListView.View>
        <GridView>
          <GridViewColumn Header="Value" Width="250" DisplayMemberBinding="{Binding Value}" />
          <GridViewColumn Header="Index" Width="80" DisplayMemberBinding="{Binding Index}" />
          <GridViewColumn Header="End" Width="80" DisplayMemberBinding="{Binding End}" />
          <GridViewColumn Header="Length" Width="80" DisplayMemberBinding="{Binding Length}" />
        </GridView>
      </ListView.View>
    </ListView>

    <Button Grid.Row="1" Content="Close" Width="80" Height="24"
            HorizontalAlignment="Right" Click="CloseButton_Click" />
  </Grid>
</Window>
