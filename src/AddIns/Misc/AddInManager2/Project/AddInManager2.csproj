<Project Sdk="LibreWPF.Sdk/11.0.0-dev">
  <PropertyGroup>
    <TargetFramework>net10.0-windows</TargetFramework>
    <RootNamespace>ICSharpCode.AddInManager2</RootNamespace>
    <AssemblyName>ICSharpCode.AddInManager2</AssemblyName>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <UseWPF>true</UseWPF>
    <EnableWindowsTargeting>true</EnableWindowsTargeting>
    <OutputType>Library</OutputType>
    <SignAssembly>true</SignAssembly>
    <AssemblyOriginatorKeyFile>..\..\..\..\Main\ICSharpCode.SharpDevelop.snk</AssemblyOriginatorKeyFile>
    <OutputPath>..\..\..\..\..\AddIns\Misc\AddInManager2\</OutputPath>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <NoWarn>$(NoWarn);CA1416;WFO1000</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <Reference Include="ICSharpCode.SharpZipLib">
      <HintPath>..\RequiredLibraries\ICSharpCode.SharpZipLib.dll</HintPath>
    </Reference>
    <Reference Include="NuGet.Core">
      <HintPath>..\..\PackageManagement\RequiredLibraries\NuGet.Core.dll</HintPath>
    </Reference>
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\..\..\Main\Base\Project\ICSharpCode.SharpDevelop.csproj" Private="false" />
    <ProjectReference Include="..\..\..\..\Main\Core\Project\ICSharpCode.Core.csproj" Private="false" />
    <ProjectReference Include="..\..\..\..\Main\ICSharpCode.Core.Presentation\ICSharpCode.Core.Presentation.csproj" Private="false" />
  </ItemGroup>
  <ItemGroup>
    <Compile Include="..\..\..\..\Main\GlobalAssemblyInfo.cs" Link="Configuration\GlobalAssemblyInfo.cs" />
    <None Include="AddInManager2.addin" CopyToOutputDirectory="Always" />
    <Resource Include="Resources\**\*" />
  </ItemGroup>
  <!-- WinForms: out of MVP scope -->
  <ItemGroup>
    <Compile Remove="Src\UpdateNotifier.cs" />
    <Compile Remove="Src\ViewModel\PackageRepositoriesViewModel.cs" />
    <Compile Remove="Src\View\PackageRepositoriesView.xaml.cs" />
    <Page Remove="Src\View\PackageRepositoriesView.xaml" />
  </ItemGroup>
</Project>
