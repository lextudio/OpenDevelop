<Project Sdk="LibreWPF.Sdk/11.0.0-dev">
  <PropertyGroup>
    <TargetFramework>net10.0-windows</TargetFramework>
    <RootNamespace>ICSharpCode.XamlBinding</RootNamespace>
    <AssemblyName>ICSharpCode.XamlBinding</AssemblyName>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <OutputPath>..\..\..\..\..\AddIns\BackendBindings\XamlBinding\</OutputPath>
    <NoWarn>$(NoWarn);CA1416;WFO1000</NoWarn>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    <EnableDefaultPageItems>false</EnableDefaultPageItems>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\..\Main\Base\Project\ICSharpCode.SharpDevelop.csproj" Private="False" />
    <ProjectReference Include="..\..\..\..\Main\Core\Project\ICSharpCode.Core.csproj" Private="False" />
    <ProjectReference Include="..\..\..\DisplayBindings\XmlEditor\Project\XmlEditor.csproj" Private="False" />
    <ProjectReference Include="..\..\..\..\..\..\wpf-labs\src\DevFlow\LeXtudio.DevFlow.Agent.Core\LeXtudio.DevFlow.Agent.Core.csproj" Private="False" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="*.cs" />
    <Compile Include="Properties\AssemblyInfo.cs" />
    <Compile Include="..\..\..\..\Main\GlobalAssemblyInfo.cs" Link="Properties\GlobalAssemblyInfo.cs" />
  </ItemGroup>

  <ItemGroup>
    <None Include="XamlBinding.addin">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <!-- XmlEditor.csproj (referenced above) itself references AvalonEdit.AddIn.csproj, whose own
       AvalonEdit.AddIn.addin (CopyToOutputDirectory=Always) propagates transitively into every
       downstream consumer's output - including this one - regardless of Private="False". That
       collides at AddInTree-load time with the real AvalonEdit.AddIn.addin already loaded from
       its own directory ("Name 'ICSharpCode.AvalonEdit' is used by ..." warning), which can cascade
       into unrelated addins failing to load. Scoped fix here rather than touching the shared
       XmlEditor/AvalonEdit.AddIn projects (WixBinding.csproj has the same reference chain and
       hasn't been verified against a change there). -->
  <Target Name="RemovePropagatedAvalonEditAddinCopy" AfterTargets="Build">
    <Delete Files="$(OutDir)AvalonEdit.AddIn.addin" Condition="Exists('$(OutDir)AvalonEdit.AddIn.addin')" />
  </Target>
</Project>
