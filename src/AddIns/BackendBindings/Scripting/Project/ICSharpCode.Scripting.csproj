  <ItemGroup>
    <ProjectReference Include="..\..\..\..\Libraries\AvalonEdit\ICSharpCode.AvalonEdit\ICSharpCode.AvalonEdit.csproj" Private="false" />
    <ProjectReference Include="..\..\..\..\Libraries\NRefactory\ICSharpCode.NRefactory\ICSharpCode.NRefactory.csproj" Private="false" />
    <ProjectReference Include="..\..\..\..\Main\Base\Project\ICSharpCode.SharpDevelop.csproj" Private="false" />
    <ProjectReference Include="..\..\..\..\Main\Core\Project\ICSharpCode.Core.csproj" Private="false" />
    <ProjectReference Include="..\..\..\Analysis\UnitTesting\UnitTesting.csproj" Private="false" />
  </ItemGroup>
  <ItemGroup>
    <Compile Include="..\..\..\..\Main\GlobalAssemblyInfo.cs" Link="Configuration\GlobalAssemblyInfo.cs" />
  </ItemGroup>
  <!-- WinForms: out of MVP scope -->
  <ItemGroup>
    <Compile Remove="Src\ScriptingDesignerGenerator.cs" />
    <Compile Remove="Src\ScriptingDesignerLoader.cs" />
    <Compile Remove="Src\ScriptingNameCreationService.cs" />
    <Compile Remove="Src\IComponentCreator.cs" />
    <Compile Remove="Src\IComponentWalker.cs" />
    <Compile Remove="Src\IScriptingCodeDomSerializer.cs" />
    <Compile Remove="Src\ScriptingCodeBuilder.cs" />
    <Compile Remove="Src\IScriptingDesignerGenerator.cs" />
  </ItemGroup>
</Project>
