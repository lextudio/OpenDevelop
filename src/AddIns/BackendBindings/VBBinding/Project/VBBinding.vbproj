<Project Sdk="LibreWPF.Sdk/11.0.0-dev">
  <PropertyGroup>
    <TargetFramework>net10.0-windows</TargetFramework>
    <RootNamespace>ICSharpCode.VBBinding</RootNamespace>
    <AssemblyName>ICSharpCode.VBBinding</AssemblyName>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <UseWPF>true</UseWPF>
    <OutputType>Library</OutputType>
    <OutputPath>..\..\..\..\..\AddIns\BackendBindings\VBBinding\</OutputPath>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <VBRuntime>Embed</VBRuntime>
    <OptionStrict>Off</OptionStrict>
    <OptionCompare>Binary</OptionCompare>
    <OptionInfer>On</OptionInfer>
    <NoWarn>$(NoWarn);BC30260</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <None Include="VBBinding.addin" CopyToOutputDirectory="Always" />
    <Compile Remove="OptionPanels\TextEditorOptions.xaml.vb" />
    <Page Remove="OptionPanels\TextEditorOptions.xaml" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\..\..\Main\Base\Project\ICSharpCode.SharpDevelop.csproj" Private="false" />
    <ProjectReference Include="..\..\..\..\Main\Core\Project\ICSharpCode.Core.csproj" Private="false" />
    <ProjectReference Include="..\..\..\..\Main\ICSharpCode.Core.Presentation\ICSharpCode.Core.Presentation.csproj" Private="false" />
  </ItemGroup>
</Project>
